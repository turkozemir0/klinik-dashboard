# LiveKit Cloud
LIVEKIT_URL=wss://stoaix-ai-infra-wgd3xles.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# AI providers
DEEPGRAM_API_KEY=your_deepgram_key
CARTESIA_API_KEY=your_cartesia_key
OPENAI_API_KEY=your_openai_key

# Supabase (service role — server only)
SUPABASE_URL=https://iylabpsokydolhuhvvwi.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Klinik config
CLINIC_ID=supabase_clinic_uuid_buraya

# Cartesia voice ID — cartesia.ai/voices'dan seç
# Türkçe için multilingual model önerilir
CARTESIA_VOICE_ID=79a125e8-cd45-4c13-8a67-188112f4dd22

# n8n webhook (opsiyonel — çağrı sonu log için)
N8N_CALL_LOG_WEBHOOK=https://your-n8n-instance/webhook/call-ended

# ── Outbound calling ────────────────────────────────────────────────
# 1. Twilio Console → Elastic SIP Trunk → Credentials → Credential List oluştur
# 2. setup_outbound_sip.py çalıştır → LIVEKIT_SIP_OUTBOUND_TRUNK_ID alırsın
TWILIO_SIP_USERNAME=stoaix-outbound
TWILIO_SIP_PASSWORD=your_sip_password
TWILIO_SIP_TERMINATION_URI=stoaix.pstn.twilio.com
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=ST_xxxxxxxxxxxxxxxx   # setup_outbound_sip.py çıktısından
OUTBOUND_CALLER_ID=+13185698481
