# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase — service role (server-only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# OpenAI
OPENAI_API_KEY=sk-...

# Demo clinic — Supabase'deki demo klinik UUID'si
DEMO_CLINIC_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Demo portal erişimi
DEMO_EMAIL=sen@email.com
DEMO_PASSWORD=gizli_sifre
DEMO_AUTH_SECRET=rastgele_uzun_bir_string_buraya  # openssl rand -hex 32 ile üret

# LiveKit — Voice Demo için (panel.stoaix.com server-side)
# Aynı değerleri Vercel env vars'a da ekle
LIVEKIT_URL=wss://stoaix-ai-infra-wgd3xles.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
