    {
      "parameters": {
        "jsCode": "const conv = $('Is Cold Final?').item.json;\nconst msgsRaw = $input.item.json;\nconst msgs = Array.isArray(msgsRaw) ? msgsRaw : [msgsRaw];\n\nconst text = msgs.filter(m => m && m.content).reverse().map(m => m.role + ': ' + m.content).join('\\n');\n\nconst cd = conv.collected_data || {};\n\nconst prompt = [\n  { role: 'system', content: `Sen bir klinik asistanısın. Hastaya follow-up mesajı yazacaksın. Hastanın önceki konuşma diline uygun yaz. Max 3 cümle. Doğal, sıcak, baskısız. Sadece mesaj metnini yaz.` },\n  { role: 'user', content: `Hasta: ${cd.name || 'İsimsiz'}\\nHizmet: ${cd.interested_service || 'Genel'}\\nPain point: ${cd.pain_point || '-'}\\nSon konuşma ${conv.daysSince} gün önce.\\nTür: ${conv.followupType}\\n\\nSon mesajlar:\\n${text}\\n\\n${conv.followupType === 'cold_final' ? 'Son follow-up. Nazik kapanış yap.' : conv.followupType.includes('cold') ? 'Soğuk hasta, çok yumuşak ol.' : 'Hâlâ ilgili olabilir, değer sun.'}` }\n];\n\nreturn [{ json: { ...conv, followupPrompt: prompt } }];"
      },
