      "parameters": {
        "jsCode": "const aiResp = $input.item.json;\nconst prev = $('Build Followup Prompt').item.json;\nlet msg = '';\ntry {\n  msg = aiResp.choices[0].message.content;\n} catch(e) {\n  msg = 'Merhaba, sizinle tekrar iletişime geçmek istedik. Herhangi bir sorunuz olursa bize yazabilirsiniz.';\n}\nreturn [{ json: { ...prev, followupMessage: msg } }];"
