    {
      "parameters": {
        "jsCode": "const raw = $input.item.json;\nconst allConvs = Array.isArray(raw) ? raw : [raw];\nconst now = new Date();\nconst followups = [];\n\nfor (const conv of allConvs) {\n  if (!conv || !conv.id || conv.human_takeover === true) continue;\n  \n  const lastMsg = new Date(conv.last_message_at);\n  const hoursSince = (now - lastMsg) / 36e5;\n  const daysSince = hoursSince / 24;\n  const score = conv.lead_score || 0;\n  let type = null;\n\n  // Active 24h no response\n  if (conv.status === 'active' && hoursSince >= 24 && hoursSince < 26)\n    type = 'first_reminder';\n\n  // Warm nurturing\n  if (conv.status === 'nurturing' && score >= 40) {\n    if (daysSince >= 3 && daysSince < 4) type = 'warm_day4';\n    if (daysSince >= 11 && daysSince < 12) type = 'warm_day11';\n    if (daysSince >= 14 && daysSince < 15) type = 'warm_to_cold';\n  }\n\n  // Cold nurturing\n  if (conv.status === 'nurturing' && score < 40) {\n    if (daysSince >= 30 && daysSince < 31) type = 'cold_month1';\n    if (daysSince >= 60 && daysSince < 61) type = 'cold_month2';\n    if (daysSince >= 90 && daysSince < 91) type = 'cold_final';\n  }\n\n  if (type)\n    followups.push({ json: { ...conv, followupType: type, daysSince: Math.round(daysSince) } });\n}\n\nif (followups.length === 0)\n  return [{ json: { hasFollowups: false } }];\n\nreturn followups.map(f => ({ ...f, json: { ...f.json, hasFollowups: true } }));"
      },
