    {
      "parameters": {
        "jsCode": "const aiResp = $input.item.json;\nconst prev = $('Build Summary Prompt').item.json;\nlet summary = '', approach = '';\n\ntry {\n  const parsed = JSON.parse(aiResp.choices[0].message.content);\n  summary = parsed.summary || 'Özet oluşturulamadı';\n  approach = parsed.suggested_approach || 'Standart yaklaşım önerilir';\n} catch(e) {\n  summary = 'Özet oluşturulamadı';\n  approach = 'Standart yaklaşım önerilir';\n}\n\nconst cd = prev.collectedData || {};\n\nconst noteBody = `🤖 AI Qualification Raporu\\n━━━━━━━━━━━━━━━━━━━━━━━━━━━\\n\\n📋 ÖZET\\n${summary}\\n\\n👤 HASTA BİLGİLERİ\\nAd: ${cd.name || 'Belirtilmedi'}\\nHizmet: ${cd.interested_service || 'Belirtilmedi'}\\nPain Point: ${cd.pain_point || 'Belirtilmedi'}\\nTimeline: ${cd.timeline || 'Belirtilmedi'}\\nBütçe: ${cd.budget_awareness || 'Sorulmadı'}\\nDaha Önce: ${cd.previous_consultation || 'Belirtilmedi'}\\nÖn Görüşme: ${cd.preferred_consultation_type || 'Belirtilmedi'}\\nTercih: ${cd.preferred_day_time || 'Belirtilmedi'}\\nSağlık: ${cd.special_health_notes || 'Yok'}\\n${prev.imagesReceived > 0 ? '📎 Görsel: ' + prev.imagesReceived + ' adet' : ''}\\n\\n📊 LEAD SCORE: ${prev.score}/100\\n\\n💡 ÖNERİLEN YAKLAŞIM\\n${approach}\\n━━━━━━━━━━━━━━━━━━━━━━━━━━━`;\n\nreturn [{ json: { ...prev, summary, approach, noteBody } }];"
      },
