    {
      "parameters": {
        "jsCode": "const conversation = $('Get Full Conversation').item.json;\nconst conv = Array.isArray(conversation) ? conversation[0] : conversation;\nconst messagesRaw = $('Get All Messages').item.json;\nconst messages = Array.isArray(messagesRaw) ? messagesRaw : [messagesRaw];\nconst inputData = $('Handoff Input').item.json;\n\nconst messagesText = messages.filter(m => m && m.content).map(m => \n  `${m.role === 'user' ? 'HASTA' : 'ASİSTAN'}: ${m.content}`\n).join('\\n');\n\nconst summaryPrompt = [\n  { role: 'system', content: `Sen bir satış analisti asistanısın. Hasta-asistan WhatsApp konuşmasını analiz et. HER ZAMAN TÜRKÇE yaz.\\n\\nJSON formatında yanıt ver:\\n{\\n  \"summary\": \"2-3 cümlelik konuşma özeti\",\\n  \"suggested_approach\": \"Satışcı bu hastayla nasıl konuşmalı? Hassas noktalar, öneriler\"\\n}` },\n  { role: 'user', content: `Konuşma:\\n${messagesText}\\n\\nToplanan Veriler: ${JSON.stringify(conv.collected_data || {})}\\nLead Score: ${inputData.lead_score || 0}` }\n];\n\nreturn [{ json: {\n  ...inputData,\n  summaryPrompt,\n  collectedData: conv.collected_data || {},\n  leadSignals: conv.lead_signals || {},\n  imagesReceived: conv.images_received || 0,\n  score: inputData.lead_score || 0\n} }];"
      },
      "id": "4bdbba56-c9a5-4341-9ecb-b215d6f2ca33",
