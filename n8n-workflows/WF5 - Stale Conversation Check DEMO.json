    {
      "parameters": {
        "jsCode": "const raw = $input.item.json;\nconst convs = Array.isArray(raw) ? raw : (raw && raw.id ? [raw] : []);\n\nif (convs.length === 0) return [{ json: { hasStale: false } }];\n\nreturn convs.map(c => {\n  const msgCount = c.message_count || 0;\n  const currentScore = c.lead_score || 0;\n  // Geçerli DB statüleri: active, handed_off, closed\n  // 2+ mesaj: müşteriyle etkileşim olmuş → active tut ama skoru düşür\n  // 0-1 mesaj: hiç etkileşim yok → kapat\n  const newStatus = msgCount >= 2 ? 'active' : 'closed';\n  const newScore = Math.max(0, currentScore - 15);\n\n  return {\n    json: {\n      ...c,\n      hasStale: true,\n      newStatus,\n      newScore,\n      newTag: 'cold_lead'\n    }\n  };\n});"
      },
      "id": "507ddede-e461-4f95-a8fe-cf031b647498",
      "name": "Classify Stale",
